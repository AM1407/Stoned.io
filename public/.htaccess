# Raise PHP limits for PDF email attachments (mod_php only — ignored on PHP-FPM)
<IfModule mod_php.c>
    php_value post_max_size 64M
    php_value upload_max_filesize 64M
    php_value memory_limit 128M
</IfModule>
<IfModule mod_php8.c>
    php_value post_max_size 64M
    php_value upload_max_filesize 64M
    php_value memory_limit 128M
</IfModule>
